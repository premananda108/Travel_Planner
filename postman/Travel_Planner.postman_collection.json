                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Chicago Art Expedition (Updated)\",\n  \"description\": \"An updated description for the art expedition.\"\n}"
