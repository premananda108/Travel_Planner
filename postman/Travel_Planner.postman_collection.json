    {
      "name": "Places",
      "item": [
        {
          "name": "Add Place to Project",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"external_id\": \"24645\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/projects/{{project_id}}/places",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "projects",
                "{{project_id}}",
                "places"
              ]
            },
            "description": "Adds a new place to a project after validating the external ID in the Art Institute API. Max limit of 10 items."
          },
          "response": []
        },
        {
          "name": "List Places in Project",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/projects/{{project_id}}/places",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "projects",
                "{{project_id}}",
                "places"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Single Place",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/projects/{{project_id}}/places/{{place_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "projects",
                "{{project_id}}",
                "places",
                "{{place_id}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Update Place (Notes & Visited)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notes\": \"Beautiful impressionist artwork, highly recommended!\",\n  \"is_visited\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/projects/{{project_id}}/places/{{place_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "projects",
                "{{project_id}}",
                "places",
                "{{place_id}}"
              ]
            },
            "description": "Updates notes and/or toggles is_visited. If all project places are visited, project completeness resets/recalculates."
          },
          "response": []
        },
        {
          "name": "Remove Place from Project",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/projects/{{project_id}}/places/{{place_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "projects",
                "{{project_id}}",
