        {
          "name": "Delete Project",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/projects/{{project_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "projects",
                "{{project_id}}"
              ]
            },
            "description": "Deletes a project. Fails if any places are marked as visited."
          },
          "response": []
