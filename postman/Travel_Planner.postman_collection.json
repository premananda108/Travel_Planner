    {
      "name": "Projects",
      "item": [
        {
          "name": "Create Project (Empty)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Summer Vacation in Chicago\",\n  \"description\": \"Visiting the best museums and parks\",\n  \"start_date\": \"2026-07-15\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/projects",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "projects"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Create Project with Places",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Chicago Art Expedition\",\n  \"description\": \"A curated trip to view famous artworks\",\n  \"start_date\": \"2026-08-01\",\n  \"places\": [\n    \"27992\",\n    \"129884\",\n    \"16568\"\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/projects/with-places",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "projects",
                "with-places"
              ]
            },
            "description": "Creates a project and imports places from the Art Institute of Chicago API in one request. External IDs are validated."
          },
          "response": []
        },
        {
          "name": "List Projects",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/projects?skip=0&limit=20",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "projects"
              ],
              "query": [
                {
                  "key": "skip",
                  "value": "0"
                },
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "is_completed",
                  "value": "false",
                  "disabled": true
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Single Project",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/projects/{{project_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "projects",
                "{{project_id}}"
              ]
            }
          },
          "response": []
        },
